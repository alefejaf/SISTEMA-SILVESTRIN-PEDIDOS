# Modelo de configuração de acesso do sistema (login via Google Sheets).
#
# Este é só um MODELO com valores fictícios — copie para
# .streamlit/secrets.toml e preencha com os valores reais. O arquivo
# secrets.toml NÃO deve ser commitado no Git (já está no .gitignore); este
# .example é o único que deve ir para o repositório.
#
# Passo a passo:
# 1. Copie este arquivo para .streamlit/secrets.toml.
# 2. Crie uma planilha Google Sheets com duas abas:
#      usuarios: usuario | nome | senha_hash | salt | perfil | ativo
#      logs:     data_hora | usuario | nome | evento | status | detalhe
# 3. No Google Cloud Console, crie/use um projeto, ative as APIs
#    "Google Sheets API" e "Google Drive API", crie uma Service Account e
#    gere uma chave JSON para ela.
# 4. Compartilhe a planilha (botão Compartilhar) com o e-mail da Service
#    Account (campo client_email abaixo) como Editor.
# 5. Copie os campos da chave JSON baixada para a seção [gcp_service_account]
#    abaixo (são os mesmos nomes de campo do JSON) — depois APAGUE o
#    arquivo JSON baixado do computador/projeto, ele não deve ficar
#    guardado em lugar nenhum além do Secrets do Streamlit.
# 6. Preencha [google_sheets] com o sheet_id da planilha (trecho da URL
#    entre /d/ e /edit).
# 7. Gere o hash+salt de cada senha rodando: python scripts/gerar_hash_senha.py
#    e cole os valores impressos nas colunas salt e senha_hash da aba
#    usuarios (nunca guarde a senha em texto puro na planilha).
# 8. No Streamlit Community Cloud, cole o mesmo conteúdo (com os valores
#    reais) no painel do app em "Settings" -> "Secrets" — nunca suba o
#    arquivo em si.
#
# Perfis disponíveis: admin, usuario, visualizador.
#   - admin/usuario: podem processar PDF, baixar Excel e editar/salvar o
#     DE/PARA na aba CONFIGURAÇÕES.
#   - visualizador: só visualiza os dados; não salva CONFIGURAÇÕES nem
#     baixa arquivos.
#
# Conta master (seção [master] abaixo): login independente do Google
# Sheets, continua funcionando mesmo se a planilha estiver fora do ar.
# Gere o hash+salt com o mesmo scripts/gerar_hash_senha.py.
#
# IMPORTANTE sobre private_key: use aspas DUPLAS (string básica do TOML),
# como no exemplo abaixo — assim o "\n" dentro da string vira quebra de
# linha de verdade, que é o formato que a chave PEM precisa. Não copie a
# chave com aspas simples (o "\n" ficaria como texto literal, quebrando o
# login) nem com string multi-linha (""") do TOML, que também reformata as
# quebras de linha.
#
# NOTA: hoje o código (grade_app/google_sheets.py) só lê
# [google_sheets] sheet_id — os campos spreadsheet_id, usuarios_worksheet
# e logs_worksheet abaixo ficam disponíveis para uso futuro (nomes de aba
# configuráveis), mas ainda não têm efeito no código atual.

[gcp_service_account]
type = "service_account"
project_id = "SEU_PROJECT_ID"
private_key_id = "SEU_PRIVATE_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"
client_email = "sua-service-account@seu-projeto.iam.gserviceaccount.com"
client_id = "SEU_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "SEU_CLIENT_X509_CERT_URL"
universe_domain = "googleapis.com"

[google_sheets]
sheet_id = "ID_DA_SUA_PLANILHA_GOOGLE_SHEETS"
spreadsheet_id = "ID_DA_SUA_PLANILHA_GOOGLE_SHEETS"
usuarios_worksheet = "usuarios"
logs_worksheet = "logs"

[master]
usuario = "alefe.junior"
nome = "Alefe Junior"
senha_hash = "HASH_EXEMPLO"
salt = "SALT_EXEMPLO"
perfil = "admin"
